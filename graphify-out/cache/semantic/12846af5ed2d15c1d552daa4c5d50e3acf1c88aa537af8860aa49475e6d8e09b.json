{"nodes": [{"id": "spec_md_go_python_boundary_section_10_4", "label": "SPEC.md \u00a710.4 (Go owns catalog authority; Python optional embedding worker)", "file_type": "document", "source_file": "SPEC.md", "source_location": "\u00a710.4", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_md_lexical_baseline_section_10_1", "label": "SPEC.md \u00a710.1 (lexical-baseline-must-stand principle)", "file_type": "document", "source_file": "SPEC.md", "source_location": "\u00a710.1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_md_eval_first_section_4_8", "label": "SPEC.md \u00a74.8 (evaluation-before-confidence)", "file_type": "document", "source_file": "SPEC.md", "source_location": "\u00a74.8", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_md_eval_framework_section_14", "label": "SPEC.md \u00a714 (scenario-based eval framework)", "file_type": "document", "source_file": "SPEC.md", "source_location": "\u00a714", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_md_indexed_fields_section_10_2", "label": "SPEC.md \u00a710.2 (indexed fields for lexical scoring)", "file_type": "document", "source_file": "SPEC.md", "source_location": "\u00a710.2", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_md_graceful_degradation_section_4_10", "label": "SPEC.md \u00a74.10 (graceful degradation requirement)", "file_type": "document", "source_file": "SPEC.md", "source_location": "\u00a74.10", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_md_three_tools_section_9", "label": "SPEC.md \u00a79 (findTool/describeTool/callTool contract)", "file_type": "document", "source_file": "SPEC.md", "source_location": "\u00a79", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_md_rrf_calibration_section_10_3", "label": "SPEC.md \u00a710.3 (RRF k + relevance floors calibrated by evals)", "file_type": "document", "source_file": "SPEC.md", "source_location": "\u00a710.3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_md_root", "label": "SPEC.md (master product specification)", "file_type": "document", "source_file": "SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_ozy_thesis", "label": "Ozy Product Thesis (configure once, index persistently)", "file_type": "rationale", "source_file": "SPEC.md", "source_location": "\u00a73", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tool access should be configured once, indexed persistently, searched by capability, and exposed to agents through a minimal instructional interface. The agent should not need to see every available downstream tool at startup."}, {"id": "spec_ozy_core_principles", "label": "Eleven Core Principles (\u00a74)", "file_type": "rationale", "source_file": "SPEC.md", "source_location": "\u00a74", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Capability brokerage over proxying; one config source of truth; small stable agent surface (3 MVP tools); persistent searchable catalog; instructional responses; live-gated invocation; token economy as first-class quality; evaluation before confidence; adapter-neutral core; local-first and privacy-respecting; observable and diagnosable."}, {"id": "spec_ozy_find_tool", "label": "findTool Contract (\u00a79.1)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a79.1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_ozy_describe_tool", "label": "describeTool Contract (\u00a79.2)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a79.2", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_ozy_call_tool", "label": "callTool Contract (\u00a79.3)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a79.3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_ozy_tool_ref", "label": "toolRef Naming Model (<serverId>.<downstreamToolName>)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a78", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_ozy_rrf", "label": "Reciprocal Rank Fusion (RRF, k=60)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a710.3", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "RRF is rank-based so BM25 lexical scores and cosine similarities from the sidecar need not be calibrated to a common scale. With no semantic signal, RRF over the single lexical list reduces to lexical order, so degraded path is identical to today's baseline. The use/ambiguous decision is made on the RRF gap between top two; no_good_match is gated on an absolute component floor (normalized lexical relevance OR cosine similarity) because RRF alone carries no absolute relevance."}, {"id": "spec_ozy_catalog_freshness", "label": "Catalog Freshness Values (fresh/stale)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a78.1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_ozy_agent_instruction", "label": "agentInstruction Quality Criteria", "file_type": "rationale", "source_file": "SPEC.md", "source_location": "\u00a74.5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Actionable: tell the agent the next concrete action. Conditional: distinguish retry/do-not-retry/ask-user/choose-alternative/refresh/report-failure cases. Grounded: base instructions only on known catalog/runtime/error state, do not imply successful execution, hidden retries, or unavailable capabilities."}, {"id": "spec_ozy_token_economy", "label": "Token Economy Quality Attribute", "file_type": "rationale", "source_file": "SPEC.md", "source_location": "\u00a74.7, \u00a713", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_ozy_embedding_sidecar", "label": "Python Embedding Sidecar Architecture", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a710.4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Go owns runtime/daemon/MCP/CLI/catalog authority/online search/lexical BM25; Python sidecar owns the embedding model, embedding-metadata store (SQLite, toolRef <-> vector_id map, content hashes, model/version metadata, raw float32 vectors), and the ANN index. The sidecar does NOT own Ozy's authoritative catalog of tools, schemas, or runtime status. The vector index is a derived artifact, rebuildable from SQLite. Vector backend selection is fixed before the first index and immutable after."}, {"id": "spec_ozy_result_cache", "label": "Result Cache Configuration (cache.enabled/ttlSeconds/maxEntries)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a711", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cache memoizes findTool/describeTool and read-only callTool results within TTL, keyed by content hash folded with the catalog generation (findTool) or the target tool's schemaHash (describe/call). callTool is cached only for tools whose downstream readOnlyHint is true; write tools and unknown intent always invoke live; failures are never cached."}, {"id": "spec_ozy_eval_framework", "label": "Eval Framework Scenario Families", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a714", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec_ozy_live_gated_invocation", "label": "Live-Gated Invocation Rule", "file_type": "rationale", "source_file": "SPEC.md", "source_location": "\u00a74.6", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Search and describe may be stale-tolerant. Calling tools is not. Ozy must not fabricate execution, silently call stale schemas, or hide downstream availability problems. If a downstream server is offline, schema drift is detected, or argument validation fails, Ozy must return structured, repair-oriented errors. No retry amplification."}], "edges": [{"source": "spec_ozy_rrf", "target": "spec_tool_search", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SPEC.md", "source_location": "\u00a710.3", "weight": 1.0}, {"source": "spec_ozy_embedding_sidecar", "target": "spec_ozy_rrf", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "SPEC.md", "source_location": "\u00a710.4", "weight": 1.0}, {"source": "spec_ozy_live_gated_invocation", "target": "spec_ozy_call_tool", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SPEC.md", "source_location": "\u00a74.6 -> \u00a79.3", "weight": 1.0}, {"source": "spec_ozy_agent_instruction", "target": "spec_ozy_call_tool", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SPEC.md", "source_location": "\u00a74.5 -> \u00a79.3 agentInstruction on failures", "weight": 1.0}, {"source": "spec_ozy_token_economy", "target": "spec_ozy_find_tool", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SPEC.md", "source_location": "\u00a74.7 -> \u00a79.1 schema preview not full schema", "weight": 1.0}, {"source": "spec_ozy_core_principles", "target": "spec_ozy_embedding_sidecar", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SPEC.md", "source_location": "\u00a74.10 local-first -> \u00a710.4 graceful lexical fallback", "weight": 1.0}, {"source": "spec_ozy_catalog_freshness", "target": "spec_ozy_tool_ref", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "SPEC.md", "source_location": "\u00a78.1 ties to \u00a78 toolRef stability", "weight": 1.0}], "hyperedges": [{"id": "spec_md_architectural_invariants", "label": "SPEC.md architectural invariants (lexical baseline, eval-first, Go authority, graceful degradation)", "nodes": ["spec_md_lexical_baseline_section_10_1", "spec_md_eval_first_section_4_8", "spec_md_go_python_boundary_section_10_4", "spec_md_graceful_degradation_section_4_10", "spec_md_three_tools_section_9"], "relation": "form", "confidence": "EXTRACTED", "confidence_score": 0.95, "source_file": "SPEC.md"}, {"id": "agent_facing_three_tools", "label": "Ozy Agent-Facing Tool Surface (3 stable MCP tools)", "nodes": ["spec_ozy_find_tool", "spec_ozy_describe_tool", "spec_ozy_call_tool", "readme_ozy_three_tools"], "relation": "form", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SPEC.md"}, {"id": "hybrid_search_pipeline", "label": "Hybrid Search Pipeline (lexical + RRF + embedding sidecar + JSONL)", "nodes": ["spec_ozy_rrf", "spec_tool_search", "spec_ozy_embedding_sidecar", "sidecar_readme_python_sidecar", "internal_sidecar_readme_go_client", "internal_sidecar_readme_jsonl_protocol", "sidecar_readme_vector_backend", "sidecar_readme_sqlite_store"], "relation": "participate_in", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "SPEC.md"}]}